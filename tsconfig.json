{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "paths": {
      "~~/*": ["./*"]
    }
  },
  "include": [
    "nuxt.config.ts",
    "app.vue",
    "pages/**/*.vue",
    "components/**/*.vue",
    "server/**/*.ts",
    "shared/**/*.ts",
    "scripts/**/*.ts",
    "mocks/*.ts",
    "app/**/*.vue",
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.tsx",
  ]
}

